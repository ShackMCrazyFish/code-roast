// prisma/schema.prisma

generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ============================================
// ENUMS
// ============================================

enum VoteType {
  UP
  DOWN
}

enum NotificationType {
  NEW_ROAST
  NEW_COMMENT
  NEW_VOTE
  REPUTATION_CHANGE
  MENTION
  ACHIEVEMENT
}

enum AchievementType {
  FIRST_POST
  FIRST_ROAST
  HELPFUL_ROAST_10
  CODE_MASTER
  POPULAR_POST
  WEEK_STREAK
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  username     String   @unique
  passwordHash String
  name         String?
  avatar       String?
  githubId     Int?     @unique
  githubUrl    String?
  bio          String?  @db.Text
  reputation   Int      @default(0) @map("reputation")
  streakDays   Int      @default(0)
  lastActiveAt DateTime @default(now())

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  posts              Post[]
  roasts             Roast[]           @relation("Roaster")
  receivedRoasts     Roast[]           @relation("Roastee")
  comments           Comment[]
  votes              Vote[]
  bookmarks          Bookmark[]
  notifications      Notification[]
  userTags           UserTag[]
  achievements       UserAchievement[]
  followers          Follow[]          @relation("Follower")
  following          Follow[]          @relation("Following")
  feedEntries        FeedEntry[]
  feedActor          FeedEntry[]       @relation("FeedActor")
  notificationsActor Notification[]    @relation("NotificationActor")

  @@index([reputation(sort: Desc)])
  @@index([username])
  @@index([lastActiveAt])
  @@map("users")
}

model Post {
  id          String  @id @default(cuid())
  title       String
  description String? @db.Text
  code        String? @db.Text
  githubUrl   String? @map("github_url")
  language    String
  linesCount  Int     @default(0) @map("lines_count")
  viewCount   Int     @default(0) @map("view_count")
  isResolved  Boolean @default(false) @map("is_resolved")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  // Relations
  roasts      Roast[]
  comments    Comment[]
  votes       Vote[]
  bookmarks   Bookmark[]
  postTags    PostTag[]
  feedEntries FeedEntry[]

  @@index([language])
  @@index([createdAt(sort: Desc)])
  @@index([authorId])
  @@index([isResolved])
  @@map("posts")
}

model Roast {
  id        String @id @default(cuid())
  content   String @db.Text
  lineStart Int?   @map("line_start")
  lineEnd   Int?   @map("line_end")
  helpful   Int    @default(0)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId String @map("author_id")
  author   User   @relation("Roaster", fields: [authorId], references: [id], onDelete: Cascade)

  postId String @map("post_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  targetUserId String? @map("target_user_id")
  targetUser   User?   @relation("Roastee", fields: [targetUserId], references: [id])

  parentId String? @map("parent_id")
  parent   Roast?  @relation("RoastReplies", fields: [parentId], references: [id])
  replies  Roast[] @relation("RoastReplies")

  // Relations
  votes      Vote[]
  comments   Comment[]
  feedEnties FeedEntry[]

  @@index([postId])
  @@index([authorId])
  @@index([helpful(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@map("roasts")
}

model Comment {
  id      String @id @default(cuid())
  content String @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  authorId String @map("author_id")
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  postId String? @map("post_id")
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  roastId String? @map("roast_id")
  roast   Roast?  @relation(fields: [roastId], references: [id], onDelete: Cascade)

  parentId String?   @map("parent_id")
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id])
  replies  Comment[] @relation("CommentReplies")

  @@index([postId])
  @@index([roastId])
  @@index([authorId])
  @@index([createdAt(sort: Desc)])
  @@map("comments")
}

// ============================================
// INTERACTION MODELS
// ============================================

model Vote {
  id   String   @id @default(cuid())
  type VoteType

  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String? @map("post_id")
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  roastId String? @map("roast_id")
  roast   Roast?  @relation(fields: [roastId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, roastId])
  @@index([userId])
  @@map("votes")
}

model Bookmark {
  id String @id @default(cuid())

  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String @map("post_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@index([userId])
  @@map("bookmarks")
}

model Follow {
  id String @id @default(cuid())

  createdAt DateTime @default(now()) @map("created_at")

  followerId String @map("follower_id")
  follower   User   @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)

  followingId String @map("following_id")
  following   User   @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

// ============================================
// TAXONOMY MODELS
// ============================================

model Tag {
  id          String  @id @default(cuid())
  name        String  @unique
  description String? @db.Text
  usageCount  Int     @default(0) @map("usage_count")

  createdAt DateTime @default(now()) @map("created_at")

  posts PostTag[]
  users UserTag[]

  @@index([name])
  @@index([usageCount(sort: Desc)])
  @@map("tags")
}

model PostTag {
  postId String @map("post_id")
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  tagId String @map("tag_id")
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@map("post_tags")
}

model UserTag {
  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  tagId String @map("tag_id")
  tag   Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([userId, tagId])
  @@map("user_tags")
}

// ============================================
// FEED & NOTIFICATIONS
// ============================================

model FeedEntry {
  id    String @id @default(cuid())
  type  String // 'post', 'roast', 'follow'
  score Float  @default(0) // для ранжирования ленты

  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String? @map("post_id")
  post   Post?   @relation(fields: [postId], references: [id], onDelete: SetNull)

  roastId String? @map("roast_id")
  roast   Roast?  @relation(fields: [roastId], references: [id], onDelete: SetNull)

  actorId String? @map("actor_id") // кто совершил действие
  actor   User?   @relation("FeedActor", fields: [actorId], references: [id])

  @@index([userId, createdAt(sort: Desc)])
  @@index([score(sort: Desc)])
  @@map("feed_entries")
}

model Notification {
  id      String           @id @default(cuid())
  type    NotificationType
  content String           @db.Text
  isRead  Boolean          @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  actorId String @map("actor_id")
  actor   User   @relation("NotificationActor", fields: [actorId], references: [id])

  postId    String? @map("post_id")
  roastId   String? @map("roast_id")
  commentId String? @map("comment_id")

  @@index([userId, isRead])
  @@index([userId, createdAt(sort: Desc)])
  @@map("notifications")
}

// ============================================
// ACHIEVEMENTS
// ============================================

model Achievement {
  id          String          @id @default(cuid())
  name        String          @unique
  description String
  type        AchievementType
  icon        String
  points      Int             @default(10)

  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id String @id @default(cuid())

  earnedAt DateTime @default(now()) @map("earned_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  achievementId String      @map("achievement_id")
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@map("user_achievements")
}
